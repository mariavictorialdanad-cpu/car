* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #f4f7f6;
    color: #333;
    line-height: 1.6;
}

header {
    background: #fff;
    padding: 1rem 5%;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: #2ecc71;
}

.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 50px 10%;
    background: #fff;
}

.hero-content {
    max-width: 500px;
}

.hero-content h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #2c3e50;
}

.btn-primary {
    display: inline-block;
    background: #2ecc71;
    color: white;
    padding: 12px 30px;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    margin-top: 20px;
    transition: 0.3s;
}

.btn-primary:hover {
    background: #27ae60;
}

.features {
    padding: 50px 10%;
    text-align: center;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 30px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
}

footer {
    text-align: center;
    padding: 20px;
    background: #2c3e50;
    color: white;
}
